{
  "name": "@datalayer/primer-rjsf",
  "description": "React JSON Schema Form (RJSF) for Primer",
  "version": "1.0.2",
  "main": "lib/index.js",
  "keywords": [
    "react",
    "json-schema-form",
    "primer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/datalayer/primer-addons.git"
  },
  "homepage": "https://datalayer.github.io/primer-rjsf",
  "bugs": {
    "url": "https://github.com/datalayer/primer-rjsf/issues"
  },
  "license": "BSD-3-Clause",
  "files": [
    "lib/**/*.*"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "build:lib": "npm run clean:lib && tsc",
    "build-storybook": "build-storybook",
    "clean:lib": "rimraf lib tsconfig.tsbuildinfo",
    "deploy": "gh-pages -d dist",
    "dev": "vite",
    "predeploy": "npm run build",
    "preview": "vite preview",
    "start": "vite",
    "storybook": "start-storybook -p 6006",
    "watch:lib": "tsc -w"
  },
  "dependencies": {
    "@datalayer/primer-addons": "^1.0.12",
    "@rjsf/core": "^5.3.0",
    "@rjsf/utils": "^5.3.0",
    "@rjsf/validator-ajv6": "^5.3.0",
    "@rjsf/validator-ajv8": "^5.3.0",
    "ajv": "^8.12.0",
    "ajv-i18n": "^4.2.0",
    "jss": "^10.10.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "styled-components": "^5.3.10"
  },
  "devDependencies": {
    "@babel/core": "^7.21.0",
    "@monaco-editor/react": "^4.4.6",
    "@storybook/addon-actions": "9.0.8",
    "@storybook/addon-essentials": "9.0.0-alpha.12",
    "@storybook/addon-interactions": "9.0.0-alpha.10",
    "@storybook/addon-links": "^9.0.15",
    "@storybook/builder-vite": "^9.0.15",
    "@storybook/react": "^9.0.15",
    "@storybook/testing-library": "^0.2.2",
    "@types/prettier": "^3.0.0",
    "@types/react": "18.3.20",
    "@types/react-dom": "18.3.6",
    "@vitejs/plugin-react": "^4.5.2",
    "babel-loader": "^8.3.0",
    "gh-pages": "^5.0.0",
    "prettier": "^3.3.2",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
